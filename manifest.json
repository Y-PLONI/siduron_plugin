{
  "schemaVersion": 1,
  "id": "com.moshenahari.siduron",
  "name": "סידורון",
  "version": "1.0.0",
  "description": "סידור תפילה לפי נוסחי תימן, ספרד, עדות-המזרח ואשכנז, עם זיהוי אוטומטי של זמני היום, התאריך העברי, החגים והתוספות לתפילה (יעלה ויבוא, על הנסים, ספירת העומר, טל/גשם ועוד) — מבוסס על נתוני אוצריא.",
  "author": "Moshe Nahari (פורט לאוצריא)",
  "homepage": "https://github.com/",
  "entrypoint": "index.html",
  "icon": "icon/icon.png",
  "stability": "beta",
  "minAppVersion": "0.9.3",
  "sdkVersion": "1.x",
  "permissions": [
    "app.info.read",
    "calendar.read",
    "settings.read",
    "plugin.storage.read",
    "plugin.storage.write",
    "ui.feedback",
    "events.subscribe:theme.changed",
    "events.subscribe:calendar.date_changed",
    "events.subscribe:settings.changed"
  ],
  "network": {
    "enabled": false,
    "allowlist": []
  },
  "contributes": {
    "toolTab": {
      "title": "סידורון",
      "order": 300,
      "allowOrderBeforeBuiltIns": false,
      "defaultPinned": true,
      "iconName": "book_24_regular"
    }
  }
}
